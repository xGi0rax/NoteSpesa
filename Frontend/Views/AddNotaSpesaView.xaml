<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ergon.Views.AddNotaSpesaView"
             xmlns:viewmodel="clr-namespace:Ergon.ViewModels"
			 xmlns:model="clr-namespace:Ergon.Models"
             xmlns:local="clr-namespace:Ergon.Services"
             x:DataType="viewmodel:AddNotaSpesaViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="White"
			 HideSoftInputOnTapped="True">

	<Grid RowDefinitions="*, Auto, Auto">
		<!-- Schermata di caricamento -->
		<Grid Grid.RowSpan="3"
			IsVisible="{Binding IsLoading}" 
			BackgroundColor="White" 
			ZIndex="999">
			<VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
				<ActivityIndicator IsRunning="{Binding IsLoading}" 
								   Color="{StaticResource Primary}" />
				<Label Text="{Binding LoadingText}" 
					   TextColor="{StaticResource Primary}" 
					   FontAttributes="Bold" 
					   FontSize="16"
					   HorizontalTextAlignment="Center" />
			</VerticalStackLayout>
		</Grid>

		<ScrollView x:Name="MainScrollView" Grid.Row="0">
			<VerticalStackLayout Padding="20" Spacing="12" IsEnabled="{Binding CanEdit}" >
				<VerticalStackLayout.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnBackgroundTapped" />
				</VerticalStackLayout.GestureRecognizers>

				<!-- Dati comuni a tutte le spese -->
				<Label Text="DATI GENERALI" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>

				<!-- Cliente -->
				<VerticalStackLayout Spacing="2">
					<HorizontalStackLayout Spacing="7" 
										   VerticalOptions="Center"
										   Margin="5, 0, 0, 0">
						<Label Text="{x:Static local:Constants.REFER_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
						<Label Text="Cliente" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
					</HorizontalStackLayout>

					<Border Style="{StaticResource InputBorderStyle}">
						<Border.Triggers>
							<DataTrigger TargetType="Border" Binding="{Binding HaSpeseInLista}" Value="True">
								<Setter Property="IsEnabled" Value="False" />
								<Setter Property="Opacity" Value="0.5" />
							</DataTrigger>
						</Border.Triggers>
						<Border.GestureRecognizers>
							<TapGestureRecognizer Command="{Binding ApriRicercaClienteCommand}" />
						</Border.GestureRecognizers>

						<Grid ColumnDefinitions="*, Auto" Padding="12">
							<Label Grid.Column="0" 
								   Text="{Binding ClienteSelezionatoRagSoc}" 
								   VerticalOptions="Center" 
								   TextColor="Black" />

							<Label Grid.Column="1"
								   Text="{x:Static local:Constants.EXPANDE_ICON}" 
								   Style="{x:StaticResource MaterialIcon}" 
								   VerticalOptions="Center" 
								   HorizontalOptions="Center"
								   TextColor="Gray"
								   InputTransparent="True" />
						</Grid>
					</Border>
				</VerticalStackLayout>

				<!-- Riepilogo spese inserite -->
				<Border Style="{StaticResource InputBorderStyle}" 
						Margin="0, -10, 0, 5"
						Padding="0" 
						IsVisible="{Binding HaSpeseInLista}">

					<VerticalStackLayout>
						<Grid ColumnDefinitions="Auto, *, Auto" Padding="12">
							<Grid.GestureRecognizers>
								<TapGestureRecognizer Command="{Binding ToggleRiepilogoCommand}" />
							</Grid.GestureRecognizers>

							<Label Grid.Column="0" 
								   Text="{x:Static local:Constants.RECEIPT_ICON}" 
								   Style="{x:StaticResource MaterialIcon}" 
								   TextColor="Black"
								   VerticalOptions="Center"
								   Margin="0,0,7,0"/>

							<Label Grid.Column="1" 
									Text="Riepilogo spese inserite" 
									FontAttributes="Bold" 
									VerticalOptions="Center"/>

							<Label Grid.Column="2"
									Text="{x:Static local:Constants.EXPANDE_ICON}" 
									Style="{x:StaticResource MaterialIcon}" 
									VerticalOptions="Center" 
									TextColor="{StaticResource Primary}"
									InputTransparent="True">
								<Label.Triggers>
									<DataTrigger TargetType="Label" 
													 Binding="{Binding IsRiepilogoVisible}" 
													 Value="True">
										<Setter Property="Rotation" Value="180" />
									</DataTrigger>
								</Label.Triggers>
							</Label>
						</Grid>

						<BoxView HeightRequest="1" 
								 BackgroundColor="{StaticResource Gray200}" 
								 IsVisible="{Binding IsRiepilogoVisible}"
								 Margin="12,0"/>

						<VerticalStackLayout IsVisible="{Binding IsRiepilogoVisible}" Padding="5">
							<VerticalStackLayout BindableLayout.ItemsSource="{Binding SpeseInserite}" >
								<BindableLayout.ItemTemplate>
									<DataTemplate x:DataType="model:SpesaDettaglio">
										<Grid ColumnDefinitions="*, Auto, Auto" Padding="12,8,12,8">
											<VerticalStackLayout Grid.Column="0">
												<Label Text="{Binding tipologia}" FontAttributes="Bold" FontSize="14"/>
												<Label Text="{Binding da_data, StringFormat='{0:dd/MM/yyyy}'}" FontSize="Caption" TextColor="Gray"/>
											</VerticalStackLayout>
											<Label Grid.Column="1" 
												   Text="{Binding importo, StringFormat='{0:F2} €'}" 
												   VerticalOptions="Center" 
												   FontAttributes="Bold"
												   FontSize="14"
												   Margin="0,1,0,0"/>
											<Label Grid.Column="2"
												   Text="{x:Static local:Constants.DELETE_FOREVER_ICON}"
												   Style="{StaticResource MaterialIcon}"
												   BackgroundColor="Transparent" 
												   TextColor="#960018"
												   FontSize="26"
												   VerticalOptions="Center"
												   HorizontalOptions="Center"
												   Margin="15,0,0,0">
												<Label.GestureRecognizers>
													<TapGestureRecognizer 
														Command="{Binding Path=BindingContext.RimuoviNotaDaRiepilogoCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
														CommandParameter="{Binding .}" />
												</Label.GestureRecognizers>
											</Label>
										</Grid>
									</DataTemplate>
								</BindableLayout.ItemTemplate>
							</VerticalStackLayout>
						</VerticalStackLayout>
					</VerticalStackLayout>
				</Border>

				<!-- Form inserimento singola spesa -->
				<Label Text="DETTAGLIO SPESA" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>

				<!-- Da data e A data -->
				<Grid ColumnDefinitions="*,*" ColumnSpacing="10">
					<VerticalStackLayout Grid.Column="0" Spacing="2">
						<HorizontalStackLayout Spacing="7" 
											   VerticalOptions="Center"
											   Margin="5, 0, 0, 0">
							<Label Text="{x:Static local:Constants.EVENT_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
							<Label Text="Da data" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
						</HorizontalStackLayout>
						<Border Style="{StaticResource InputBorderStyle}">
							<DatePicker MinimumDate="{Binding DataMinima}" 
										MaximumDate="{Binding DataMassima}"
										Date="{Binding TempDaData}"
										Format="dd/MM/yyyy" 
										Margin="{OnPlatform iOS='10,0,5,0', Default='5,0'}"/>
						</Border>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="1" Spacing="2">
						<HorizontalStackLayout Spacing="7" 
											   VerticalOptions="Center"
											   Margin="5, 0, 0, 0">
							<Label Text="{x:Static local:Constants.EVENT_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
							<Label Text="A data" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
						</HorizontalStackLayout>
						<Border Style="{StaticResource InputBorderStyle}">
							<DatePicker Date="{Binding TempAData}" 
										MaximumDate="{Binding DataMassima}"
										MinimumDate="{Binding DataMinima}"
										Format="dd/MM/yyyy" 
										Margin="{OnPlatform iOS='10,0,5,0', Default='5,0'}"/>
						</Border>
					</VerticalStackLayout>
				</Grid>

				<!-- Tipologia -->
				<VerticalStackLayout Spacing="2">
					<HorizontalStackLayout Spacing="7" 
										   VerticalOptions="Center"
										   Margin="5, 0, 0, 0">
						<Label Text="{x:Static local:Constants.LIST_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
						<Label Text="Tipologia" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
					</HorizontalStackLayout>
					<Border Style="{StaticResource InputBorderStyle}">
						<Grid ColumnDefinitions="*, Auto">
							<Picker Grid.Column="0"
									Grid.ColumnSpan="2"
									Title="Seleziona la tipologia..." 
									ItemsSource="{Binding OpzioniTipologia}" 
									SelectedItem="{Binding TempTipologia}"
									TextColor="Black" 
									TitleColor="{StaticResource Gray200}"
									Margin="10,0"/>

							<Label Grid.Column="1"
								Text="{x:Static local:Constants.EXPANDE_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								VerticalOptions="Center" 
								TextColor="Gray"
								Margin="0,0,10,0"
								InputTransparent="True" />
						</Grid>
					</Border>
				</VerticalStackLayout>

				<!-- Importo e Valuta -->
				<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="2">
					<HorizontalStackLayout Spacing="7" 
										   VerticalOptions="Center"
										   Margin="5, 0, 0, 0"
										   Grid.Row="0" Grid.Column="0">
						<Label Text="{x:Static local:Constants.PAYMENTS_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
						<Label Text="Importo" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
					</HorizontalStackLayout>
					<Label Grid.Row="0" Grid.Column="1" Text="Valuta" FontAttributes="Bold" />

					<Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InputBorderStyle}">
						<Entry x:Name="ImportoEntry"
							   Placeholder="0,00" 
							   Text="{Binding TempImporto}" 
							   TextChanged="OnImportoTextChanged"
							   HorizontalTextAlignment="End"
							   Margin="10,0"
							   VerticalOptions="Center" 
							   Unfocused="OnImportoUnfocused">
							<Entry.Keyboard>
								<OnPlatform x:TypeArguments="Keyboard">
									<On Platform="Android" Value="Telephone" />
									<On Platform="iOS" Value="Numeric" />
								</OnPlatform>
							</Entry.Keyboard>
						</Entry>
					</Border>

					<Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputBorderStyle}">
						<Label Text="€" 
							   VerticalTextAlignment="Center" 
							   HorizontalTextAlignment="Center"
							   FontSize="Medium"
							   WidthRequest="45"
							   Margin="10,0" />
					</Border>
				</Grid>

				<!-- Metodo di pagamento-->
				<VerticalStackLayout Spacing="2">
					<HorizontalStackLayout Spacing="7" 
											VerticalOptions="Center"
											Margin="5, 0, 0, 0">
						<Label Text="{x:Static local:Constants.WALLET_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
						<Label Text="Metodo di pagamento" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
					</HorizontalStackLayout>
					<Border Style="{StaticResource InputBorderStyle}">
						<Grid ColumnDefinitions="*, Auto">
							<Picker Grid.Column="0"
									Grid.ColumnSpan="2"
									Title="Seleziona il metodo di pagamento..." 
									ItemsSource="{Binding OpzioniTipoPag}" 
									SelectedItem="{Binding TempTipoPag}"
									TextColor="Black" 
									TitleColor="{StaticResource Gray200}"
									Margin="10,0" />

							<Label Grid.Column="1" 
								   Text="{x:Static local:Constants.EXPANDE_ICON}" 
								   Style="{x:StaticResource MaterialIcon}" 
								   VerticalOptions="Center" 
								   TextColor="Gray"
								   Margin="0,0,10,0"
								   InputTransparent="True" />
						</Grid>
					</Border>
				</VerticalStackLayout>

				<!-- Numero dipendenti e Con cliente-->
				<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="2">
					<HorizontalStackLayout Spacing="7" 
										   VerticalOptions="Center"
										   Margin="5, 0, 0, 0"
										   Grid.Row="0" Grid.Column="0">
						<Label Text="{x:Static local:Constants.GROUPS_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>	
						<Label Text="Dipendenti Ergon" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
					</HorizontalStackLayout>
					<Label Grid.Row="0" Grid.Column="1" Text="Con cliente" FontAttributes="Bold" />

					<Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InputBorderStyle}" HeightRequest="45">
						<Grid ColumnDefinitions="Auto, *, Auto">
							<Button Grid.Column="0" 
									Text="-" 
									Command="{Binding DecrementaDipCommand}"
									BackgroundColor="Transparent"
									TextColor="{StaticResource Primary}"
									FontAttributes="Bold"
									FontSize="25"
									WidthRequest="45"
									Padding="0" />

							<Entry Grid.Column="1" 
								   Text="{Binding TempNumDip}" 
								   Keyboard="Numeric"
								   HorizontalTextAlignment="Center"
								   VerticalOptions="Center"
								   TextColor="Black"
								   Margin="0" />

							<Button Grid.Column="2" 
									Text="+" 
									Command="{Binding IncrementaDipCommand}"
									BackgroundColor="Transparent"
									TextColor="{StaticResource Primary}"
									FontAttributes="Bold"
									FontSize="20"
									WidthRequest="45"
									Padding="0" />
						</Grid>
					</Border>

					<Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputBorderStyle}">
						<CheckBox IsChecked="{Binding TempFlagConCli}" />
					</Border>
				</Grid>

				<!-- Note -->
				<VerticalStackLayout Spacing="2">
					<HorizontalStackLayout Spacing="5">
						<HorizontalStackLayout Spacing="7" 
											   VerticalOptions="Center"
											   Margin="5, 0, 0, 0">
							<Label Text="{x:Static local:Constants.NOTES_ICON}" 
									Style="{x:StaticResource MaterialIcon}" 
									TextColor="Black"/>	
							<Label Text="Note" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
						</HorizontalStackLayout>

						<Label Text="(facoltative) " 
							   TextColor="Gray" 
							   FontAttributes="Italic"
							   IsVisible="True"
							   Margin="2, 3, 0, 0">
							<Label.Triggers>
								<DataTrigger TargetType="Label" 
											 Binding="{Binding TempTipologia}" 
											 Value="Altro">
									<Setter Property="IsVisible" Value="False" />
								</DataTrigger>
							</Label.Triggers>
						</Label>

						<Label Text="*" 
							   TextColor="Red" 
							   FontAttributes="Bold"
							   IsVisible="False">
							<Label.Triggers>
								<DataTrigger TargetType="Label" 
											 Binding="{Binding TempTipologia}" 
											 Value="Altro">
									<Setter Property="IsVisible" Value="True" />
								</DataTrigger>
							</Label.Triggers>
						</Label>
					</HorizontalStackLayout>

					<Border Style="{StaticResource InputBorderStyle}">
						<Entry Text="{Binding TempNote}" 
							   Placeholder="Note aggiuntive" 
							   Margin="10,0">
							<Entry.Triggers>
								<DataTrigger TargetType="Entry" 
											 Binding="{Binding TempTipologia}" 
											 Value="Altro">
									<Setter Property="Placeholder" Value="Descrizione obbligatoria..." />
								</DataTrigger>
							</Entry.Triggers>
						</Entry>
					</Border>
				</VerticalStackLayout>

				<!-- Sezione scontrino e bottoni -->
				<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" 
					  ColumnSpacing="10" RowSpacing="2">

					<HorizontalStackLayout Spacing="7" 
										   VerticalOptions="Center"
										   Margin="5, 0, 0, 0"
										   Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
						<Label Text="{x:Static local:Constants.RECEIPT_ICON}" 
								Style="{x:StaticResource MaterialIcon}" 
								TextColor="Black"/>
						<Label Text="Foto scontrino" FontAttributes="Bold" Margin="3, 3, 0, 0"/>
					</HorizontalStackLayout>

					<!-- Bottone aggiunta -->
					<Button Grid.Row="0" 
							Grid.Column="1" 
							Text="{x:Static local:Constants.ADD_PHOTO_ICON}"
							Style="{StaticResource MaterialIcon}"
							BackgroundColor="{StaticResource Primary}"
							TextColor="White"
							HeightRequest="45"
							WidthRequest="70"
							CornerRadius="10"
							VerticalOptions="Center"
							Margin="0,5,0,5"
							IsVisible="True"
							Command="{Binding ScegliFonteFotoCommand}">
						<Button.Triggers>
							<DataTrigger TargetType="Button" Binding="{Binding HasFoto}" Value="True">
								<Setter Property="IsVisible" Value="False" />
							</DataTrigger>
						</Button.Triggers>
					</Button>

					<!-- Bottone rimozione -->
					<Button Grid.Row="0" 
							Grid.Column="1"
							Text="{x:Static local:Constants.CLOSE_ICON}"
							FontSize="16"
							Style="{StaticResource MaterialIcon}"
							BackgroundColor="#960018" 
							TextColor="White" 
							HeightRequest="35"
							WidthRequest="45"
							CornerRadius="10"
							VerticalOptions="Center"
							Margin="0,5,0,5"
							IsVisible="{Binding HasFoto}"
							Command="{Binding RimuoviFotoCommand}" />

					<!-- Anteprima scontrino -->
					<Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
							IsVisible="{Binding MostraImmagineLocale}" 
							Padding="0" Margin="40,15,40,10" 
							Stroke="{StaticResource Gray200}" StrokeThickness="1" 
							HeightRequest="300" 
							HorizontalOptions="Fill" 
							VerticalOptions="Start">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="8"/>
						</Border.StrokeShape>
						<Image Source="{Binding FotoVisualizzabilePath}" 
							   Aspect="AspectFill" 
							   HorizontalOptions="Fill" 
							   VerticalOptions="Fill" />
					</Border>

					<!-- Anteprima se immagine non presente -->
					<Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
							IsVisible="{Binding MostraPlaceholderRemoto}" 
							Padding="20" Margin="40,15,40,10" 
							Stroke="#E0E0E0" 
							BackgroundColor="#F5F5F5" 
							StrokeThickness="1" 
							HeightRequest="150" 
							HorizontalOptions="Fill">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="8"/>
						</Border.StrokeShape>
						<VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
							<Label Text="Foto disponibile solo in remoto" 
								   TextColor="#666666" 
								   FontAttributes="Italic" 
								   HorizontalOptions="Center" 
								   FontSize="15"/>
						</VerticalStackLayout>
					</Border>

					<!-- Dati estratti dallo scontrino -->
					<VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                         Spacing="2" 
                         Margin="5, 10, 5, 0"
                         IsVisible="{Binding HasFoto}">

						<Label Text="DATI DOCUMENTO" 
							   FontAttributes="Bold" 
							   TextColor="{StaticResource Primary}" 
							   Margin="0,0,0,10"/>

						<VerticalStackLayout Spacing="2">
							<Label Text="Numero documento" 
								   FontAttributes="Bold" 
								   Margin="3, 0, 0, 0" 
								   FontSize="Caption" 
								   TextColor="Black"/>
							<Border Style="{StaticResource InputBorderStyle}">
								<Entry Text="{Binding TempNrDoc}" 
									   Placeholder="N. Documento estratto..." 
									   Margin="10,0"/>
							</Border>
						</VerticalStackLayout>

						<VerticalStackLayout Spacing="2">
							<Label Text="Data e ora documento" 
								   FontAttributes="Bold" 
								   Margin="3, 0, 0, 0" 
								   FontSize="Caption" 
								   TextColor="Black"/>
							<Border Style="{StaticResource InputBorderStyle}">
								<Entry Text="{Binding TempDataDoc}" 
									   Placeholder="Data documento estratto..." 
									   Margin="10,0"/>
							</Border>
						</VerticalStackLayout>

						<VerticalStackLayout Spacing="2">
							<Label Text="Ragione sociale" 
								   FontAttributes="Bold" 
								   Margin="3, 0, 0, 0" 
								   FontSize="Caption" 
								   TextColor="Black"/>
							<Border Style="{StaticResource InputBorderStyle}">
								<Entry Text="{Binding TempRagSoc}" 
									   Placeholder="Ragione sociale estratta..." 
									   Margin="10,0"/>
							</Border>
						</VerticalStackLayout>

						<VerticalStackLayout Spacing="2">
							<Label Text="Partita IVA" 
								   FontAttributes="Bold" 
								   Margin="3, 0, 0, 0"
								   FontSize="Caption" 
								   TextColor="Black"/>
							<Border Style="{StaticResource InputBorderStyle}">
								<Entry Text="{Binding TempPartitaIva}" 
									   Placeholder="Partita IVA estratta..." 
									   Margin="10,0"/>
							</Border>
						</VerticalStackLayout>
					</VerticalStackLayout>
				</Grid>

			</VerticalStackLayout>
		</ScrollView>
		
		<!-- Bottom Bar -->
		<VerticalStackLayout Grid.Row="2" Padding="0,0">
			<BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}" Margin="0, 0, 0, 5"/>
			<VerticalStackLayout Spacing="5">
				<VerticalStackLayout.Triggers>
					<DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsEditMode}" Value="True">
						<Setter Property="IsVisible" Value="False" />
					</DataTrigger>
				</VerticalStackLayout.Triggers>

				<!-- Checkbox per posticipare il caricamento -->
				<HorizontalStackLayout Grid.Row="0" Grid.ColumnSpan="2" 
									   VerticalOptions="Center" 
									   HorizontalOptions="Center" 
									   Margin="0,0,0,-15"
									   IsVisible="{Binding IsFlagPostVisibile}">
					<CheckBox IsChecked="{Binding TempFlagPostCaricamento}" VerticalOptions="Center" />
					<Label Text="Posticipa il caricamento" VerticalTextAlignment="Center"/>
				</HorizontalStackLayout>

				<!-- Bottone aggiungi un'altra spesa -->
				<Button Text="AGGIUNGI UN'ALTRA SPESA"
						Command="{Binding AggiungiSpesaAllaNotaCommand}"
						BackgroundColor="{StaticResource Gray200}" 
						Margin="20,15,20,5" 
						TextColor="Black">
					<Button.CommandParameter>
						<x:Boolean>True</x:Boolean>
					</Button.CommandParameter>
					<Button.ImageSource>
						<FontImageSource Glyph="{x:Static local:Constants.ADD_EXPENSE_ICON}" 
										 FontFamily="MaterialIcon" 
										 Size="24" 
										 Color="Black"/>
					</Button.ImageSource>
				</Button>

				<!-- Bottone salvataggio -->
				<Button Text="SALVA NOTA"
						Command="{Binding SaveCommand}"
						BackgroundColor="{StaticResource Primary}" 
						Margin="20,0,20,-5" 
						TextColor="White"
						FontAttributes="Bold">
					<Button.ImageSource>
						<FontImageSource Glyph="{x:Static local:Constants.SAVE_ICON}" 
										 FontFamily="MaterialIcon" 
										 Size="24" 
										 Color="White"/>
					</Button.ImageSource>
				</Button>
			</VerticalStackLayout>

			<!-- Bottoni visibili in modalità modifica -->
			<Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="20,10,20,20">

				<!-- Bottone elimina se la nota è locale -->
				<Button Grid.Column="0"
						Text="ELIMINA"
						Command="{Binding EliminaNotaCommand}"
						BackgroundColor="#960018"
						TextColor="White"
						FontAttributes="Bold"
						HeightRequest="45"
						CornerRadius="10"
						IsVisible="{Binding CanDeleteLocal}" >
					<Button.ImageSource>
						<FontImageSource Glyph="{x:Static local:Constants.DELETE_ICON}" 
								 FontFamily="MaterialIcon" 
								 Size="24" 
								 Color="White"/>
					</Button.ImageSource>
				</Button>

				<!-- Bottone carica se la nota è locale -->
				<Button Grid.Column="0" Grid.ColumnSpan="2"
						Text="CARICA"
						Command="{Binding InviaNotaSingolaCommand}"
						BackgroundColor="RoyalBlue"
						TextColor="White"
						FontAttributes="Bold"
						HeightRequest="45"
						CornerRadius="10"
						IsVisible="False">
					<Button.ImageSource>
						<FontImageSource Glyph="{x:Static local:Constants.UPLOAD_ICON}" 
										 FontFamily="MaterialIcon" 
										 Size="24" 
										 Color="White"/>
					</Button.ImageSource>
					<Button.Triggers>

						<MultiTrigger TargetType="Button">
							<MultiTrigger.Conditions>
								<BindingCondition Binding="{Binding IsEditMode}" Value="True" />
								<BindingCondition Binding="{Binding IsLocalSpesa}" Value="True" />
								<BindingCondition Binding="{Binding CanEdit}" Value="True" />
							</MultiTrigger.Conditions>
							<Setter Property="IsVisible" Value="True" />
						</MultiTrigger>

						<DataTrigger TargetType="Button" Binding="{Binding CanDeleteLocal}" Value="True">
							<Setter Property="Grid.Column" Value="1" />
							<Setter Property="Grid.ColumnSpan" Value="1" />
						</DataTrigger>

					</Button.Triggers>
				</Button>
			</Grid>
			
			<Button Text="AGGIUNGI UN'ALTRA SPESA"
					Command="{Binding AggiungiSpesaModificaCommand}"
					BackgroundColor="{StaticResource Gray200}" 
					Margin="20,-10,20,10" 
					TextColor="Black"
					IsVisible="False">
				<Button.CommandParameter>
					<x:Boolean>True</x:Boolean>
				</Button.CommandParameter>
				<Button.ImageSource>
					<FontImageSource Glyph="{x:Static local:Constants.ADD_EXPENSE_ICON}" 
									 FontFamily="MaterialIcon" 
									 Size="24" 
									 Color="Black"/>
				</Button.ImageSource>
				<Button.Triggers>
					<MultiTrigger TargetType="Button">
						<MultiTrigger.Conditions>
							<BindingCondition Binding="{Binding IsEditMode}" Value="True" />
							<BindingCondition Binding="{Binding CanEdit}" Value="True" />
						</MultiTrigger.Conditions>
						<Setter Property="IsVisible" Value="True" />
					</MultiTrigger>
				</Button.Triggers>
			</Button>

			<Button Text="SALVA MODIFICHE"
					Command="{Binding SalvaModificheCommand}"
					BackgroundColor="{StaticResource Primary}"
					Margin="20,0,20,15" 
					TextColor="White"
					FontAttributes="Bold"
					IsVisible="False">
				<Button.ImageSource>
					<FontImageSource Glyph="{x:Static local:Constants.SAVE_ICON}" 
						 FontFamily="MaterialIcon" 
						 Size="24" 
						 Color="White"/>
				</Button.ImageSource>
				<Button.Triggers>
					<DataTrigger TargetType="Button" Binding="{Binding IsEditMode}" Value="True">
						<Setter Property="IsVisible" Value="True" />
					</DataTrigger>

					<DataTrigger TargetType="Button" Binding="{Binding CanEdit}" Value="False">
						<Setter Property="IsVisible" Value="False" />
					</DataTrigger>
				</Button.Triggers>
			</Button>

			<Label Text="Non è possibile modificare questa nota spesa."
				   TextColor="Red" 
				   HorizontalOptions="Center" 
				   Margin="0,0,0,10"
				   IsVisible="False">
				<Label.Triggers>
					<DataTrigger TargetType="Label" Binding="{Binding CanEdit}" Value="False">
						<Setter Property="IsVisible" Value="True" />
					</DataTrigger>
				</Label.Triggers>
			</Label>

		</VerticalStackLayout>


	</Grid>
</ContentPage>